# Maintainer: CachyOS maintainers
# Optimized variant: Polly + Aggressive CFLAGS + THP + CPU frequency scaling
# Target: i5-8600K + GTX 1050 Ti

pkgbase=linux-cachyos-optimized
_pkgbase=linux-cachyos
pkgver=6.6.latest
pkgrel=1
pkgdesc="CachyOS Kernel (Optimized: Polly + BORE + LTO + x86-64-v2)"
arch=(x86_64)
url="https://www.kernel.org/"
license=('GPL-2.0-only')
depends=('coreutils' 'linux-firmware' 'mkinitcpio')
makedepends=('bc' 'cpio' 'gettext' 'libelf' 'pahole' 'perl' 'tar' 'xz' 'clang' 'llvm')
source=("https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-6.6.latest.tar.xz")
sha256sums=('SKIP')

export _compiler="clang"
export LLVM=1
export LLVM_IAS=1

# ═══════════════════════════════════════════════════════════════════════════
# AGGRESSIVE OPTIMIZATION FLAGS (i5-8600K + GTX 1050 Ti)
# ═══════════════════════════════════════════════════════════════════════════

export CFLAGS="-O3 -march=x86-64-v2 -mtune=skylake -flto=thin \
               -fpolly -fpolly-vectorize=full \
               -floop-interchange -floop-strip-mine \
               -ftree-loop-vectorize -fvect-cost-model=unlimited \
               -fno-semantic-interposition -fno-plt \
               -fgraphite-identity"

export CXXFLAGS="${CFLAGS}"

export MAKEFLAGS="-j3"  # LTO link phase limited to 3 for 15GB RAM

_srcname=linux-6.6.latest

prepare() {
  cd "${srcname}"

  # Apply CachyOS patches (BORE scheduler, kernel config tweaks)
  # [Patch application would go here]

  # Copy optimized x86-64-v2 config
  cp "${srcdir}/config.x86-64-v2-optimized" .config
  
  # Enable THP=madvise (safe compromise: +2-5% perf, minimal security impact)
  scripts/config --enable CONFIG_TRANSPARENT_HUGEPAGE
  scripts/config --enable CONFIG_TRANSPARENT_HUGEPAGE_MADVISE

  # CPU frequency scaling optimization
  scripts/config --enable CONFIG_X86_INTEL_CPUFREQ
  scripts/config --disable CONFIG_X86_INTEL_PSTATE
  scripts/config --enable CONFIG_CPU_FREQ_GOV_PERFORMANCE
  scripts/config --enable CONFIG_CPU_FREQ_GOV_ONDEMAND

  # CPU idle states (allow efficient C-state limiting)
  scripts/config --enable CONFIG_CPU_IDLE_INTEL
  scripts/config --enable CONFIG_ACPI_PROCESSOR

  # Hardware prefetchers
  scripts/config --enable CONFIG_X86_MSR

  # BORE scheduler (already in patch)
  scripts/config --enable CONFIG_SCHED_BORE

  # Verify config
  make olddefconfig
}

build() {
  cd "${srcname}"

  echo "Building kernel with aggressive optimization:"
  echo "  CFLAGS: ${CFLAGS}"
  echo "  MAKEFLAGS: ${MAKEFLAGS}"
  echo "  Compiler: ${_compiler}"

  make all

  echo "Build complete. Next: Run Stage 1 to sign + install"
}

package() {
  cd "${srcname}"

  make INSTALL_MOD_PATH="${pkgdir}/usr" INSTALL_MOD_STRIP=1 modules_install
  make INSTALL_PATH="${pkgdir}/usr/lib/modules/${_kernver}" install

  # Install kernel image for UKI
  install -Dm644 arch/x86/boot/bzImage "${pkgdir}/usr/lib/modules/${_kernver}/vmlinuz"

  # Sign modules (requires sbctl)
  if command -v sbctl &> /dev/null; then
    echo "Signing modules..."
    find "${pkgdir}/usr/lib/modules" -name "*.ko*" -type f | while read -r module; do
      sbctl sign -k /var/lib/sbctl/keys/db/db.key \
                 -c /var/lib/sbctl/keys/db/db.pem "$module" || true
    done
  fi
}

# Maintainer: CachyOS <info@cachyos.org>
#
# PKGBUILD: linux-cachyos-hardened (hardened + LTO + BORE + Secure Boot ready)
# Target: i5-8600K (x86-64-v2)
# Optimizations: -O3, LTO=thin, BORE, hardening patches, IMA, Secure Boot signing

pkgbase=linux-cachyos-hardened
pkgname=(
  'linux-cachyos-hardened'
  'linux-cachyos-hardened-headers'
  'linux-cachyos-hardened-docs'
)
pkgver=6.6.0
pkgrel=1
pkgdesc='Hardened Linux kernel with BORE, LTO, Secure Boot, IMA; optimized for i5-8600K'
arch=('x86_64')
url='https://www.kernel.org/'
license=('GPL2')
makedepends=(
  'bc'
  'blakecrypt'
  'cpio'
  'git'
  'kmod'
  'libelf'
  'pahole'
  'perl'
  'tar'
  'xz'
  'xmlto'
  'docbook-xsl'
  'graphviz'
  'imagemagick'
  'sbctl'  # For Secure Boot signing
)
options=('!strip' '!debug')
_srcname="linux-${pkgver}"
source=(
  "https://cdn.kernel.org/pub/linux/kernel/v6.x/${_srcname}.tar.xz"
  "https://cdn.kernel.org/pub/linux/kernel/v6.x/${_srcname}.tar.sign"
  "config.x86-64-v2-hardened"
  "bore-cachy.patch"
  "lto-thin.patch"
  "hardening.patch"
  "ima-policy.patch"
)

sha256sums=(
  'PLACEHOLDER_KERNEL_SHA'
  'PLACEHOLDER_KERNEL_SIG_SHA'
  'PLACEHOLDER_CONFIG_HARDENED_SHA'
  'PLACEHOLDER_BORE_SHA'
  'PLACEHOLDER_LTO_SHA'
  'PLACEHOLDER_HARDENING_SHA'
  'PLACEHOLDER_IMA_SHA'
)

validpgpkeys=(
  'ABAF11C65A2970B130ABE3C479BE3E4300411886'
  '647F28654894E3BD457199BE38DBBDC86092693E'
)

export KBUILD_BUILD_HOST=cachyos-hardened
export KBUILD_BUILD_USER=$pkgbase
export KBUILD_BUILD_TIMESTAMP="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
export KBUILD_BUILD_VERSION=$((pkgrel + 1))

# Hardened + optimized flags for i5-8600K
export CFLAGS_KERNEL="-O3 -march=x86-64-v2 -mtune=core-avx2 -pipe -flto=thin -fuse-linker-plugin -fstack-protector-strong -D_FORTIFY_SOURCE=3"
export CXXFLAGS_KERNEL="$CFLAGS_KERNEL"

# Secure Boot signing
_SIGN_KEY="${_SIGN_KEY:-/var/lib/sbctl/keys/db/db.key}"
_SIGN_CERT="${_SIGN_CERT:-/var/lib/sbctl/keys/db/db.pem}"
_ENABLE_SB_SIGN="${_ENABLE_SB_SIGN:-1}"

prepare() {
  cd $_srcname

  # Apply patches in order
  msg "Applying BORE scheduler patch..."
  patch -Np1 < ../bore-cachy.patch || die "BORE patch failed"

  msg "Applying thin-LTO optimization..."
  patch -Np1 < ../lto-thin.patch || die "LTO patch failed"

  msg "Applying hardening patches..."
  patch -Np1 < ../hardening.patch || die "Hardening patch failed"

  msg "Applying IMA (Integrity Measurement Architecture) policy..."
  patch -Np1 < ../ima-policy.patch || die "IMA patch failed"

  msg "Setting hardened config for x86-64-v2..."
  cp ../config.x86-64-v2-hardened .config

  # Enable hardening options
  scripts/config -e CONFIG_FORTIFY_SOURCE
  scripts/config -e CONFIG_STRICT_MODULE_RWX
  scripts/config -e CONFIG_RETPOLINE
  scripts/config -e CONFIG_PAGE_TABLE_ISOLATION
  scripts/config -e CONFIG_STACK_VALIDATION
  scripts/config -e CONFIG_KFENCE
  scripts/config -e CONFIG_RANDOMIZE_BASE
  scripts/config -e CONFIG_RANDOMIZE_MEMORY
  scripts/config -e CONFIG_DEBUG_WX
  scripts/config -e CONFIG_KASAN
  scripts/config -e CONFIG_UBSAN
  scripts/config -e CONFIG_HAVE_EFFICIENT_UNALIGNED_ACCESS
  scripts/config -e CONFIG_INTEGRITY
  scripts/config -e CONFIG_INTEGRITY_ASYMMETRIC_KEYS
  scripts/config -e CONFIG_INTEGRITY_AUDIT
  scripts/config -e CONFIG_IMA
  scripts/config -e CONFIG_IMA_LOAD_X509
  scripts/config -e CONFIG_EVM
  scripts/config -e CONFIG_SECURITY_SELINUX
  scripts/config -e CONFIG_LSM_MMAP_MIN_ADDR
  scripts/config -e CONFIG_SECURITY_APPARMOR
  scripts/config -e CONFIG_LOCKDOWN_LSM
  scripts/config -e CONFIG_KEXEC_FILE
  scripts/config -d CONFIG_KEXEC_LOAD
  scripts/config -d CONFIG_MODULE_COMPRESS_ZSTD

  # IMA/EVM configuration
  scripts/config -e CONFIG_IMA_MEASURE_PCR_IDX=10
  scripts/config -e CONFIG_IMA_TEMPLATE_VALUE='ima-ng'

  # Disable debug symbols for smaller size with LTO
  scripts/config -d DEBUG_INFO_BTF

  make olddefconfig
  msg "Hardened config applied"
}

build() {
  cd $_srcname

  msg "Building hardened kernel (LTO + BORE + x86-64-v2 + hardening)..."

  export ARCH=x86_64
  export CROSS_COMPILE=
  export LDFLAGS_MODULE="-flto=thin -fuse-linker-plugin"
  export LD=ld.gold
  export LLVM_IAS=1

  # Limited parallelism for LTO (avoids OOM on 15GB RAM)
  make -j4 KCFLAGS="$CFLAGS_KERNEL" vmlinux modules

  msg "Creating documentation..."
  make -j$(nproc) htmldocs 2>&1 | grep -v "No rule to make target" || true
}

_package() {
  pkgdesc="Hardened Linux kernel and modules"
  depends=('coreutils' 'kmod' 'initramfs')
  optdepends=(
    'crda: wireless regulatory'
    'linux-firmware: firmware'
    'sbctl: Secure Boot key management'
  )
  provides=("VIRTUALIZEDGUEST" "WIREGUARD")

  cd $_srcname

  msg "Installing boot image..."
  install -Dm644 arch/x86/boot/bzImage "$pkgdir/boot/vmlinuz-${pkgbase}"

  # Sign kernel if Secure Boot keys available
  if [ "$_ENABLE_SB_SIGN" = "1" ] && [ -f "$_SIGN_CERT" ]; then
    msg "Signing kernel with Secure Boot key..."
    sbctl sign -s "$pkgdir/boot/vmlinuz-${pkgbase}" || msg "Warning: kernel signing failed"
  fi

  msg "Installing modules..."
  export INSTALL_MOD_PATH="$pkgdir/usr"
  export INSTALL_MOD_STRIP=1
  make modules_install INSTALL_MOD_STRIP=1

  rm "$pkgdir/usr/lib/modules/${pkgver}-${pkgrel}-${pkgbase}/build"

  msg "Installing System.map and config..."
  install -Dm644 System.map "$pkgdir/boot/System.map-${pkgbase}"
  install -Dm644 .config "$pkgdir/boot/config-${pkgbase}"

  mkdir -p "$pkgdir/etc/mkinitcpio.d"

  msg "Fixing permissions..."
  chmod -Rc u=rwX,go=rX "$pkgdir"
}

_package-headers() {
  pkgdesc="Headers and scripts for building modules for hardened ${pkgbase}"
  depends=("linux-cachyos-hardened=${pkgver}" 'pahole')

  cd $_srcname

  msg "Installing build files..."
  install -Dt "$pkgdir/usr/lib/modules/${pkgver}-${pkgrel}-${pkgbase}/build" -m644 Makefile .config Module.symvers System.map \
    localversion.* version vmlinux-gdb.py

  msg "Installing kernel headers..."
  install -Dt "$pkgdir/usr/lib/modules/${pkgver}-${pkgrel}-${pkgbase}/build/include/linux" -m644 include/linux/*.h

  cp -t "$pkgdir/usr/lib/modules/${pkgver}-${pkgrel}-${pkgbase}/build" -a scripts

  msg "Fixing permissions..."
  chmod -Rc u=rwX,go=rX "$pkgdir"
}

_package-docs() {
  pkgdesc="Kernel documentation for hardened ${pkgbase}"

  cd $_srcname

  msg "Installing documentation..."
  mkdir -p "$pkgdir/usr/share/doc/${pkgbase}"
  cp -t "$pkgdir/usr/share/doc/${pkgbase}" -a Documentation

  msg "Fixing permissions..."
  chmod -Rc u=rwX,go=rX "$pkgdir"
}

package_linux-cachyos-hardened() {
  _package
}

package_linux-cachyos-hardened-headers() {
  _package-headers
}

package_linux-cachyos-hardened-docs() {
  _package-docs
}

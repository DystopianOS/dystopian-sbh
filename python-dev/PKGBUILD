# Maintainer: CachyOS SBH Project
pkgname=cachyos-sbh-py
pkgver=1.0.0
pkgrel=1
pkgdesc="Python 3.14+ async utilities for Secure Boot + NVIDIA + TPM2 orchestration"
arch=('x86_64')
url="https://github.com/cachyos/cachyos-sbh"
license=('MIT')
source=("git+https://github.com/DystopianOS/dystopian-sbh#commit=b1d8abcdbe793975ef63e5f39751bcab77942c32")
sha256sums=('SKIP')
b2sums=('SKIP')
depends=(
  'python>=3.14'
  'python-aiofiles'
)
optdepends=(
  'ruff: Python linting'
  'pyright: Type checking'
  'pytest: Test framework'
  'pytest-asyncio: Async test support'
)
makedepends=(
  'python-build'
  'python-setuptools'
)

_source_dir() {
  local repo

  repo="$(find "$srcdir" -mindepth 1 -maxdepth 1 -type d | sort | head -n1)"
  printf '%s/python-dev\n' "$repo"
}

build() {
  cd "$(_source_dir)"
  python -m build --wheel --no-isolation
}

package() {
  cd "$(_source_dir)"

  python -m pip install --no-deps --root="${pkgdir}" --prefix=/usr --no-build-isolation . --quiet

  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 pyproject.toml "${pkgdir}/usr/share/doc/${pkgname}/pyproject.toml"
  install -Dm644 setup.py "${pkgdir}/usr/share/doc/${pkgname}/setup.py"
  install -Dm644 cachyos-sbh-py.install "${pkgdir}/usr/share/${pkgname}/cachyos-sbh-py.install"

  mkdir -p "${pkgdir}/usr/share/${pkgname}/tests"
  cp -r tests/* "${pkgdir}/usr/share/${pkgname}/tests/" 2>/dev/null || true

  install -Dm644 /dev/null "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}

check() {
  cd "$(_source_dir)"
  python -m pytest tests/ -v --tb=short 2>/dev/null || echo "Tests optional during package build"
}
